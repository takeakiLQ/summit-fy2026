    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "firebase-admin": "11.11.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3"
  }
}
