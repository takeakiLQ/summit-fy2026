{
  "name": "firestore-sync",
  "version": "0.1.0",
  "description": "kpi-compute と csv-import の出力を Firestore に書き込むモジュール",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
