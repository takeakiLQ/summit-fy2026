{
  "name": "sf-extract",
  "version": "0.1.0",
  "description": "サミット営業成績ダッシュボード - Salesforce案件データ抽出モジュール（Node.jsローカル検証用）",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "extract": "tsx src/index.ts",
    "extract:all": "tsx src/index.ts --all",
    "build": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3"
  }
}
