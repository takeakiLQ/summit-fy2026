# =====================================================================
# Salesforce 接続情報
# このファイル(.env.example)を .env にコピーして編集してください。
# .env は git にコミットしないでください（.gitignore で除外済み）。
# =====================================================================

# ---------------------------------------------------------------------
# 認証フロー選択
#   username_password : Username/Password Flow（simple_salesforce相当、login.salesforce.comでOK）
#   client_credentials: Client Credentials Flow（サーバー間認証、My Domain URL必須）
# 推奨: 既存のPythonコードで使っていた認証情報があるなら username_password で開始
# ---------------------------------------------------------------------
SF_AUTH_TYPE=username_password

# ---------------------------------------------------------------------
# Salesforce ログインドメイン
#   Username/Password Flow: https://login.salesforce.com でOK
#   Client Credentials Flow: 組織のMy Domain URL（例: https://logiquest.my.salesforce.com）
# ---------------------------------------------------------------------
SF_LOGIN_URL=https://login.salesforce.com

# Salesforce インスタンスURL（任意、トークン取得時に自動で取れます）
SF_INSTANCE_URL=

# ---------------------------------------------------------------------
# Connected App の Consumer Key / Secret（両フロー共通で必要）
# ---------------------------------------------------------------------
SF_CLIENT_ID=
SF_CLIENT_SECRET=

# ---------------------------------------------------------------------
# Username/Password Flow 用（SF_AUTH_TYPE=username_password の場合のみ必要）
#   既存のPythonコード:
#     USERNAME = 'takeaki.mandokoro@logiquest.co.jp'
#     PASSWORD = 'xxxxx'
#     SECURITY_TOKEN = 'xxxxx...'
#   と同じ値をそのまま設定すればOK
# ---------------------------------------------------------------------
SF_USERNAME=
SF_PASSWORD=
SF_SECURITY_TOKEN=

# ---------------------------------------------------------------------
# Salesforce REST API バージョン
# ---------------------------------------------------------------------
SF_API_VERSION=v60.0

# 抽出対象のオブジェクト API 名（columns.jsonの値を上書き）
DEAL_OBJECT_API_NAME=

# 出力ディレクトリ
OUTPUT_DIR=./output

# 開発用フラグ（trueにすると詳細ログ）
DEBUG=false
